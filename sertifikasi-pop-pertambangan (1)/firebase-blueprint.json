{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role metadata for student, instructor, or admin",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Unique user ID"
        },
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "role": {
          "type": "string",
          "enum": ["student", "instructor", "admin"],
          "description": "Registered role of the user"
        },
        "name": {
          "type": "string",
          "description": "Display name of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user registered"
        }
      },
      "required": ["userId", "email", "role", "name", "createdAt"]
    },
    "Progress": {
      "title": "Progress",
      "description": "Tracks student learning path, module completion toggles, and dynamic strength parameters",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "User this progress belongs to"
        },
        "completedModules": {
          "type": "object",
          "description": "Map of moduleId (string) to boolean indicator of completion"
        },
        "competencyAverages": {
          "type": "object",
          "description": "Map representing average scores across different competency dimensions"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Registry update timestamp"
        }
      },
      "required": ["userId", "completedModules", "competencyAverages", "updatedAt"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "Detailed AI Assessor dialog sessions, containing scenario, user answers, and rubrics evaluation",
      "type": "object",
      "properties": {
        "assessmentId": {
          "type": "string",
          "description": "Unique identifier for this session"
        },
        "userId": {
          "type": "string",
          "description": "Evaluating candidate identifier"
        },
        "status": {
          "type": "string",
          "enum": ["active", "completed"],
          "description": "Status of the assessment interview"
        },
        "scenario": {
          "type": "string",
          "description": "Scenario posed by the AI Assessor"
        },
        "questions": {
          "type": "array",
          "description": "List of interactive question strings within this assessment flow"
        },
        "answers": {
          "type": "array",
          "description": "List of answers submitted by the candidate"
        },
        "evaluations": {
          "type": "array",
          "description": "Scored evaluations from 1-100 on rubrics (Safety, Compliance, Decision, Risk, Leadership, Comm)"
        },
        "feedback": {
          "type": "object",
          "description": "Consolidated constructive advisor pointers, mentor insights, and ideal replies"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["assessmentId", "userId", "status", "scenario", "questions", "answers", "createdAt"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Full mock practice exams complete with random question selectors, timer details, and outcomes",
      "type": "object",
      "properties": {
        "examId": {
          "type": "string",
          "description": "Simulation session key"
        },
        "userId": {
          "type": "string",
          "description": "User identifier"
        },
        "score": {
          "type": "number",
          "description": "Aggregated overall performance score out of 100"
        },
        "competencyLevel": {
          "type": "string",
          "description": "Calculated level of competency of the candidate"
        },
        "responses": {
          "type": "array",
          "description": "Map of question choices selected by the student"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Session timestamp"
        }
      },
      "required": ["examId", "userId", "score", "competencyLevel", "responses", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Primary user configuration"
    },
    "users/{userId}/progress/main": {
      "schema": { "$ref": "#/entities/Progress" },
      "description": "Learning tracking variables"
    },
    "assessments/{assessmentId}": {
      "schema": { "$ref": "#/entities/Assessment" },
      "description": "AI Asessor conversational runs"
    },
    "exams/{examId}": {
      "schema": { "$ref": "#/entities/Exam" },
      "description": "Standardized multiple-choice or scenario simulation scoring sheets"
    }
  }
}
