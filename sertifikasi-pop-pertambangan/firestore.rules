rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ID validation to prevent poisoning patterns
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$');
    }

    // User Validator
    function isValidUser(user) {
      return user.userId is string 
        && user.userId.size() <= 128
        && user.email is string
        && user.email.size() <= 200
        && user.name is string
        && user.name.size() <= 200
        && user.role in ['student', 'instructor', 'admin']
        && user.createdAt is timestamp;
    }

    // Progress Validator
    function isValidProgress(prog) {
      return prog.userId is string
        && prog.userId.size() <= 128
        && prog.completedModules is map
        && prog.competencyAverages is map
        && prog.updatedAt is timestamp;
    }

    // Assessment Validator
    function isValidAssessment(assess) {
      return assess.assessmentId is string
        && assess.assessmentId.size() <= 128
        && assess.userId is string
        && assess.userId.size() <= 128
        && assess.status in ['active', 'completed']
        && assess.scenario is string
        && assess.questions is list
        && assess.answers is list
        && assess.createdAt is timestamp;
    }

    // Exam Validator
    function isValidExam(ex) {
      return ex.examId is string
        && ex.examId.size() <= 128
        && ex.userId is string
        && ex.userId.size() <= 128
        && ex.score is number
        && ex.score >= 0
        && ex.score <= 100
        && ex.competencyLevel is string
        && ex.responses is list
        && ex.createdAt is timestamp;
    }

    // Matches for Users profiles
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']);
      allow list: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin'];
      
      // Creating profiles requires setting fields correctly and matching Auth UUID
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data) 
        && request.resource.data.role == 'student' // Force default role on client-side registration
        && request.resource.data.createdAt == request.time;
      
      // Updates cannot change role or original timestamp
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data)
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.userId == resource.data.userId;

      allow delete: if false; // Profiles are forever
    }

    // Match for users progress
    match /users/{userId}/progress/main {
      allow get: if isSignedIn() && (isOwner(userId) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']);
      allow write: if isSignedIn() && isOwner(userId) && isValidProgress(request.resource.data)
        && request.resource.data.userId == userId
        && request.resource.data.updatedAt == request.time;
    }

    // Matches for AI Assessor runs
    match /assessments/{assessmentId} {
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
      );

      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
      );

      // Create interactive assess session
      allow create: if isSignedIn() && isValidId(assessmentId) && isValidAssessment(request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.status == 'active';

      // Updates can lock state, change answers or append progress but must protect immutable fields
      // and cannot modify once terminal state 'completed' is reached.
      allow update: if isSignedIn() && isValidAssessment(request.resource.data)
        && resource.data.userId == request.auth.uid
        && resource.data.status == 'active' // Must currently be active (terminal state lock)
        && request.resource.data.assessmentId == resource.data.assessmentId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'active';
    }

    // Matches for Exam simulations
    match /exams/{examId} {
      allow get, list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
      );

      allow create: if isSignedIn() && isValidId(examId) && isValidExam(request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false; // Exams cannot be altered or removed to preserve records Integrity
    }
  }
}
